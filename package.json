  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MikeRatcliffe/NewRecipes"
  },
  "scripts": {
    "build": "gatsby build --prefix-paths",
    "build:serve": "gatsby build && gatsby serve -p 8000",
    "checkForUpdates": "npm-check -u",
    "clobber": "rm -rf .cache public node_modules package-lock.json yarn.lock",
    "clean": "gatsby clean",
    "develop": "gatsby develop",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "serve": "gatsby serve -p 8000",
    "test": "jest",
    "type-check": "tsc --noEmit"
  }
